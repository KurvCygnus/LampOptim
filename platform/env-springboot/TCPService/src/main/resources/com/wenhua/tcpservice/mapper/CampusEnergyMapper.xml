<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wenhua.tcpservice.mapper.CampusEnergyMapper">

    <resultMap id="CampusAreaResultMap" type="com.wenhua.tcpservice.pojo.campus.CampusArea">
        <id property="id" column="id"/>
        <result property="areaName" column="area_name"/>
        <result property="areaType" column="area_type"/>
        <result property="areaSize" column="area_size"/>
        <result property="lampCount" column="lamp_count"/>
        <result property="deviceCount" column="device_count"/>
        <result property="managerName" column="manager_name"/>
        <result property="managerPhone" column="manager_phone"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="monthlyEnergyConsumption" column="monthly_energy_consumption"/>
        <result property="monthlyEnergySaved" column="monthly_energy_saved"/>
        <result property="savingRate" column="saving_rate"/>
    </resultMap>

    <resultMap id="EnergyBillResultMap" type="com.wenhua.tcpservice.pojo.campus.EnergyBill">
        <id property="id" column="id"/>
        <result property="areaId" column="area_id"/>
        <result property="areaName" column="area_name"/>
        <result property="billMonth" column="bill_month"/>
        <result property="totalConsumption" column="total_consumption"/>
        <result property="totalCost" column="total_cost"/>
        <result property="savedConsumption" column="saved_consumption"/>
        <result property="savedCost" column="saved_cost"/>
        <result property="savingRate" column="saving_rate"/>
        <result property="peakConsumption" column="peak_consumption"/>
        <result property="offPeakConsumption" column="off_peak_consumption"/>
        <result property="averageDailyConsumption" column="average_daily_consumption"/>
        <result property="reportUrl" column="report_url"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="wasteAnalysis" column="waste_analysis"/>
        <result property="optimizationSuggestions" column="optimization_suggestions"/>
    </resultMap>

    <resultMap id="TeachingCaseResultMap" type="com.wenhua.tcpservice.pojo.campus.TeachingCase">
        <id property="id" column="id"/>
        <result property="caseName" column="case_name"/>
        <result property="caseType" column="case_type"/>
        <result property="description" column="description"/>
        <result property="deviceId" column="device_id"/>
        <result property="deviceName" column="device_name"/>
        <result property="dataSource" column="data_source"/>
        <result property="teachingContent" column="teaching_content"/>
        <result property="experimentGuide" column="experiment_guide"/>
        <result property="relatedCourse" column="related_course"/>
        <result property="useCount" column="use_count"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="dataPreview" column="data_preview"/>
        <result property="analysisResult" column="analysis_result"/>
    </resultMap>

    <select id="selectAreas" resultMap="CampusAreaResultMap">
        select * from campus_area
        <where>
            <if test="areaName != null and areaName != ''">
                and area_name like concat('%', #{areaName}, '%')
            </if>
            <if test="areaType != null and areaType != ''">
                and area_type = #{areaType}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBills" resultMap="EnergyBillResultMap">
        select * from energy_bill
        <where>
            <if test="areaId != null">
                and area_id = #{areaId}
            </if>
            <if test="billMonth != null and billMonth != ''">
                and bill_month = #{billMonth}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by bill_month desc
    </select>

    <select id="selectTeachingCases" resultMap="TeachingCaseResultMap">
        select * from teaching_case
        <where>
            <if test="caseType != null and caseType != ''">
                and case_type = #{caseType}
            </if>
            <if test="deviceId != null and deviceId != ''">
                and device_id = #{deviceId}
            </if>
            <if test="relatedCourse != null and relatedCourse != ''">
                and related_course like concat('%', #{relatedCourse}, '%')
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by use_count desc, create_time desc
    </select>

</mapper>
